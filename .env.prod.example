# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_DB=therapist_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_now

# -----------------------------
# Spring Boot Backend
# -----------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=therapist_db
DB_USER=postgres
DB_PASSWORD=change_me_now
PYTHON_BASE_URL=http://python-service:8000

# IMPORTANT:
# Put your public frontend URL/domain in CORS.
# Example:
# CORS_ALLOWED_ORIGINS=https://therapist.mondomaine.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Mail provider
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user@example.com
MAIL_PASSWORD=change_me_or_leave_blank
MAIL_FROM=no-reply@example.com

# If true, email codes are printed in backend logs when mail is not configured.
AUTH_EMAIL_CONSOLE_FALLBACK=true

# -----------------------------
# Python IA Service
# -----------------------------
STT_MODEL=small
STT_LANGUAGE=en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_MIN_RMS=0.01
THERAPIST_LLM_ENABLED=true
THERAPIST_LLM_PROVIDER=llama_cpp
THERAPIST_LLAMA_MODEL_PATH=LLMA/tinyllama-1.1b-chat-v1.0/tinyllama-1.1b-chat-v1.0.Q2_K.gguf
THERAPIST_LLAMA_RUNTIME_PATH=vendor/llama_cpp_runtime
THERAPIST_LLAMA_HELPER_PYTHON=.tmp/python312_runtime/python.exe
THERAPIST_LLAMA_HELPER_RUNTIME_PATH=vendor/llama_cpp_runtime312
THERAPIST_LLAMA_PREFER_HELPER=true
THERAPIST_LLAMA_N_CTX=1024
THERAPIST_LLAMA_N_THREADS=1
THERAPIST_HISTORY_MAX_TURNS=8
THERAPIST_LLM_MAX_TOKENS=12
THERAPIST_LLM_HISTORY_MAX_TURNS=1
THERAPIST_LLM_NON_BLOCKING_STARTUP=true
THERAPIST_LLM_TEMPERATURE=0.3
THERAPIST_LLM_TOP_P=0.8
TTS_LANG=en-us
TTS_RATE=165
